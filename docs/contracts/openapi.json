{
  "openapi": "3.1.0",
  "info": {
    "title": "TrustLoop API",
    "version": "0.1.0"
  },
  "paths": {
    "/api/rest/health": {
      "get": {
        "responses": {
          "200": {
            "description": "Health check",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/rest/workflows/dispatch": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkflowDispatchRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Workflow accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowDispatchResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "const": true
          },
          "service": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
          }
        },
        "required": [
          "ok",
          "service",
          "timestamp"
        ],
        "additionalProperties": false
      },
      "SupportWorkflowInput": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "workspaceId": {
            "type": "string",
            "minLength": 1
          },
          "installationId": {
            "type": "string",
            "minLength": 1
          },
          "ingressEventId": {
            "type": "string",
            "minLength": 1
          },
          "canonicalIdempotencyKey": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "workspaceId",
          "installationId",
          "ingressEventId",
          "canonicalIdempotencyKey"
        ],
        "additionalProperties": false
      },
      "CodexWorkflowInput": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "analysisId": {
            "type": "string",
            "minLength": 1
          },
          "repositoryId": {
            "type": "string",
            "minLength": 1
          },
          "pullRequestNumber": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          }
        },
        "required": [
          "analysisId",
          "repositoryId",
          "pullRequestNumber"
        ],
        "additionalProperties": false
      },
      "WorkflowDispatchRequest": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "support"
              },
              "payload": {
                "type": "object",
                "properties": {
                  "workspaceId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "installationId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "ingressEventId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "canonicalIdempotencyKey": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "workspaceId",
                  "installationId",
                  "ingressEventId",
                  "canonicalIdempotencyKey"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "type",
              "payload"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "codex"
              },
              "payload": {
                "type": "object",
                "properties": {
                  "analysisId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "repositoryId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "pullRequestNumber": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  }
                },
                "required": [
                  "analysisId",
                  "repositoryId",
                  "pullRequestNumber"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "type",
              "payload"
            ],
            "additionalProperties": false
          }
        ]
      },
      "WorkflowDispatchResponse": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "workflowId": {
            "type": "string"
          },
          "runId": {
            "type": "string"
          },
          "queue": {
            "type": "string"
          }
        },
        "required": [
          "workflowId",
          "runId",
          "queue"
        ],
        "additionalProperties": false
      }
    }
  }
}
