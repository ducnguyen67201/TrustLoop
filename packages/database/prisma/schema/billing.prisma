enum WorkspacePlanTier {
  FREE
  STARTER
  PRO
}

enum BillingPeriod {
  MONTHLY
  ANNUAL
}

enum UsageEventType {
  ANALYSIS_RUN
  DRAFT_GENERATED
  REPO_INDEXED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  UNPAID
}

model WorkspacePlan {
  id                      String              @id @default(cuid())
  workspaceId             String              @unique
  workspace               Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  tier                    WorkspacePlanTier   @default(FREE)
  billingPeriod           BillingPeriod       @default(MONTHLY)
  stripeCustomerId        String?             @unique
  stripeSubscriptionId    String?             @unique
  subscriptionStatus      SubscriptionStatus  @default(ACTIVE)
  seatLimit               Int                 @default(1)
  analysisIncludedMonthly Int                 @default(25)
  analysisOverageRateCents Int?
  repoLimitTotal          Int                 @default(2)
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  cancelAtPeriodEnd       Boolean             @default(false)
  pendingTier             WorkspacePlanTier?
  deletedAt               DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model UsageEvent {
  id              String          @id @default(cuid())
  workspaceId     String
  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  eventType       UsageEventType
  resourceId      String?
  metadata        Json?
  billingPeriod   String
  stripeSynced    Boolean         @default(false)
  stripeSyncedAt  DateTime?
  createdAt       DateTime        @default(now())

  @@index([workspaceId, eventType, billingPeriod])
  @@index([stripeSynced, createdAt])
}

model StripeWebhookEvent {
  id              String    @id @default(cuid())
  stripeEventId   String    @unique
  eventType       String
  processedAt     DateTime  @default(now())

  @@index([stripeEventId])
}
