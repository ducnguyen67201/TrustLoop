{
  "name": "@shared/rest",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsgo --noEmit",
    "lint": "biome check .",
    "test": "SKIP_ENV_VALIDATION=1 SESSION_SECRET=test-secret-minimum-16 API_KEY_PEPPER=test-pepper-minimum-16 INTERNAL_SERVICE_KEY=tli_test_key_1234567890 SLACK_SIGNING_SECRET=test-slack-secret-min16 SLACK_REPLAY_WINDOW_SECONDS=300 vitest run",
    "openapi:generate": "tsx ./scripts/generate-openapi.ts",
    "openapi:check": "tsx ./scripts/generate-openapi.ts --check"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@shared/database": "*",
    "@shared/env": "*",
    "@shared/types": "*",
    "@temporalio/client": "^1.13.0",
    "@trpc/server": "^11.0.0",
    "openai": "^6.33.0",
    "zod": "^4.0.0"
  }
}
